{
  "name": "@teleport-rs/client",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jvz-devx/teleport-rs.git",
    "directory": "packages/client"
  },
  "homepage": "https://github.com/jvz-devx/teleport-rs#readme",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "tsx --test src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "qs": "^6.13.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/qs": "^6.9.0",
    "tsx": "^4.20.6",
    "typescript": "^5.5.0"
  }
}
